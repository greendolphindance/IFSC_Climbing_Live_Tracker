{
  "name": "ifsc-boulder-live-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "build": "npm run check && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.server.json",
    "probe:ifsc": "tsx scripts/probe-ifsc.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "fastify": "^5.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "playwright": "^1.50.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
